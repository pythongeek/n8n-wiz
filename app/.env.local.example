# =============================================================================
# n8n Agent Dashboard - Local Development Environment
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# AI Model API Keys (Required)
# -----------------------------------------------------------------------------

# Moonshot (Kimi) API Key - Get from https://platform.moonshot.cn/
VITE_KIMI_API_KEY=

# Google AI Studio (Gemini) API Key - Get from https://aistudio.google.com/
VITE_GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Supabase Configuration (Required)
# -----------------------------------------------------------------------------

# Supabase Project URL - Get from https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=

# Supabase Anon Key (Public key - safe for client-side)
VITE_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# n8n Deployment Configuration (Optional)
# -----------------------------------------------------------------------------

# MCP Bridge URL (optional - for local n8n integration)
VITE_MCP_SERVER_URL=

# MCP API Key (optional)
VITE_MCP_API_KEY=

# Browser Automation URL (optional)
VITE_BROWSER_AUTOMATION_URL=

# Browser service secret (optional)
VITE_BROWSER_SECRET=

# n8n Public URL (optional - for local n8n integration)
VITE_N8N_PUBLIC_URL=

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------

# Deployment mode: 'vercel' | 'docker' | 'hybrid'
VITE_DEPLOYMENT_MODE=vercel
